{
  "name": "@doctorwu/agent-inbox",
  "version": "1.0.1",
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "bin": {
    "agent-inbox": "dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "pnpm --filter @agent-im-relay/core build && pnpm --filter @agent-im-relay/discord build && pnpm --filter @agent-im-relay/feishu build && tsdown",
    "build:sea": "node ./scripts/build-executable.mjs",
    "build:all": "pnpm run build && pnpm run build:sea",
    "prepack": "pnpm run build",
    "start": "node dist/index.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@agent-im-relay/core": "workspace:*",
    "@agent-im-relay/discord": "workspace:*",
    "@agent-im-relay/feishu": "workspace:*",
    "@types/node": "^22.10.0",
    "postject": "1.0.0-alpha.6",
    "tsdown": "^0.21.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
