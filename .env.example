DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_application_client_id_here
# Optional: restrict bot to specific guild IDs (comma-separated)
GUILD_IDS=
# Optional: Claude model override (example: claude-sonnet-4-5)
CLAUDE_MODEL=
# Optional: working directory used when spawning Claude Code (default: current process cwd)
CLAUDE_CWD=
# Optional: request timeout in milliseconds (default: 600000)
AGENT_TIMEOUT_MS=600000
# Optional: Discord stream update frequency in milliseconds (default: 1000)
STREAM_UPDATE_INTERVAL_MS=1000
# Optional: max content per Discord message edit chunk (default: 1900)
DISCORD_MESSAGE_CHAR_LIMIT=1900
