DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_application_client_id_here
# Optional: restrict bot to specific guild IDs (comma-separated)
GUILD_IDS=
# Feishu gateway app ID
FEISHU_APP_ID=
# Feishu gateway app secret
FEISHU_APP_SECRET=
# Optional: required when Feishu callback encryption is enabled
FEISHU_ENCRYPT_KEY=
# Optional: verification token for Feishu URL verification callbacks
FEISHU_VERIFICATION_TOKEN=
# Optional: Feishu Open Platform base URL
FEISHU_BASE_URL=https://open.feishu.cn
# Optional: local HTTP port for the managed Feishu gateway
FEISHU_PORT=3001
# Shared client identity used between the managed gateway and the local relay client
FEISHU_CLIENT_ID=
# Shared client secret used between the managed gateway and the local relay client
FEISHU_CLIENT_TOKEN=
# Local relay client URL for polling commands from the managed gateway
FEISHU_GATEWAY_URL=http://127.0.0.1:3001
# Optional: polling interval for the managed Feishu relay client in milliseconds
FEISHU_CLIENT_POLL_INTERVAL_MS=1000
# Optional: Claude model override (example: claude-sonnet-4-5)
CLAUDE_MODEL=
# Optional: working directory used when spawning Claude Code (default: current process cwd)
CLAUDE_CWD=
# Optional: request timeout in milliseconds (default: 600000)
AGENT_TIMEOUT_MS=600000
# Optional: path to state persistence file (default: data/sessions.json)
STATE_FILE=
# Optional: path to Claude CLI binary (default: /opt/homebrew/bin/claude)
CLAUDE_BIN=
# Optional: path to Codex CLI binary (default: /opt/homebrew/bin/codex)
CODEX_BIN=
# Optional: artifact storage root shared by Discord and Feishu adapters
ARTIFACTS_BASE_DIR=
# Optional: artifact retention window in days
ARTIFACT_RETENTION_DAYS=14
# Optional: maximum uploaded/downloaded artifact size in bytes
ARTIFACT_MAX_SIZE_BYTES=8388608
# Optional: Discord stream update frequency in milliseconds (default: 1000)
STREAM_UPDATE_INTERVAL_MS=1000
# Optional: max content per Discord message edit chunk (default: 1900)
DISCORD_MESSAGE_CHAR_LIMIT=1900
